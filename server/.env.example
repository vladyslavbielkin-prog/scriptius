# ============================================================
# Scriptius — Environment Variables
# ============================================================
# Скопіюй цей файл: cp .env.example .env
# Заповни значення нижче. Інструкція: див. SETUP.md
# ============================================================

# --- Google Cloud Speech-to-Text ---

# Project ID з Google Cloud Console (напр. "my-project-123456")
GOOGLE_PROJECT_ID=your-gcp-project-id

# Повний JSON сервіс-акаунта (ВЕСЬ вміст файлу, одним рядком!)
# Не шлях до файлу, а сам JSON. Приклад:
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
GOOGLE_CREDENTIALS_JSON=

# Регіон для Speech v2 API. Залиш europe-west4 якщо не впевнений.
GOOGLE_STT_LOCATION=europe-west4

# Движок STT: "chirp_v2" (основний, Chirp модель) або "latest_long_v1" (запасний, v1 API)
STT_ENGINE=chirp_v2

# --- Google Gemini (AI-аналіз) ---

# API ключ з Google AI Studio (aistudio.google.com → Get API Key)
GEMINI_API_KEY=your-gemini-api-key
